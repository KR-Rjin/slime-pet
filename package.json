{
  "name": "slime-pet",
  "version": "1.0.0",
  "description": "史萊姆螢幕寵物",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.slime.pet",
    "productName": "SlimePet",
    "files": [
      "main.js",
      "index.html",
      "trail.html"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "*",
    "electron-builder": "*"
  }
}
